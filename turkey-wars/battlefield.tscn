render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_burley, specular_schlick_ggx;
uniform vec3 albedo : source_color = vec3(0.2, 0.5, 0.1);
uniform float sway_speed = 1.0;
uniform float sway_strength = 0.5;
void vertex() {
    VERTEX.y += sin(VERTEX.x * 2.0 + TIME * sway_speed) * sway_strength * 0.1;
    VERTEX.x += cos(VERTEX.z * 1.5 + TIME * sway_speed * 0.8) * sway_strength * 0.05;
}
void fragment() {
    ALBEDO = albedo;
    ROUGHNESS = 0.8;
}"
